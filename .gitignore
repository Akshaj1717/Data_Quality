# =============================================================
# .gitignore — Files and folders Git should NOT track
# =============================================================

# Python cache files (auto-generated, never commit these)
__pycache__/
*.pyc
*.pyo

# Virtual environment (local dependency install, not for GitHub)
venv/
.env

# IDE settings (specific to your machine)
.idea/

# Uploaded datasets (user uploads, not source code)
uploads/

# Output files (generated by pipeline runs)
outputs/

# OS-generated files
Thumbs.db
.DS_Store
